<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Problems</title>

<style>

body{
    background:#181a20;
    color:#eaeaea;
    font-family:'Segoe UI','Roboto','Arial',sans-serif;
    margin:0;
    padding:0;
}

.container{
    max-width:1100px;
    margin:40px auto;
    background:#23272f;
    border-radius:18px;
    box-shadow:0 4px 32px #000a;
    padding:32px;
}

h1{
    text-align:center;
    margin-top:10px;
    font-size:2.5rem;
    letter-spacing:2px;
    color:#b347ff;
}

.menu {
    display: grid;

    grid-template-columns: repeat(3, 1fr);

    gap: 20px;

    margin: 32px 0;
}

/* Tablet */
@media (max-width: 1000px) {

    .menu {
        grid-template-columns: repeat(2, 1fr);
    }

}

/* Mobile */
@media (max-width: 600px) {

    .menu {
        grid-template-columns: repeat(1, 1fr);
    }

}
.problem-card{
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;

    padding:30px 20px;
    background:#2a2e3a;
    text-decoration:none;

    border-radius:12px;
    min-height:120px;

    transition:all .3s ease;

    position:relative;
    overflow:hidden;

    color: #c44dff;          /* text color */
    font-size:22px;       /* change this */
    font-weight:600;      /* optional */
}

.problem-card::before{
    content:'';
    position:absolute;
    top:0;
    left:0;

    width:100%;
    height:5px;

    background:linear-gradient(
        90deg,
        #9333ff,
        #c44dff
    );
}

.problem-card:hover{
    background:#32363f;
    transform:translateY(-5px);
    color:white;           /* text color on hover */
}
.problem-title{
    color:#c44dff;
    font-size:1.25rem;
    font-weight:bold;
    text-align:center;
}



.error{
    color:red;
    text-align:center;
}

</style>
</head>

<body>

<div class="container">

<h1>Problems</h1>

{{if .error}}
<div class="error">
    {{.error}}
</div>
{{end}}

<div class="menu">

{{range .Problems}}

<a href="/problems/{{.ID}}" class="problem-card">
    {{.Title}}
</a>

{{end}}

</div>

</div>

</body>
</html>