<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">

<title>{{.Problem.Title}}</title>

<style>

body{
    background:#181a20;
    color:#eaeaea;
    font-family:'Segoe UI',sans-serif;
    margin:0;
}

.container{
    max-width:1400px;
    margin:auto;
    padding:20px;
}

h1{
    color:#c44dff;
}

.top-bar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

#editor{
    width:100%;
    height:70vh;
    border-radius:12px;
    overflow:hidden;
}

.controls{
    display:flex;
    gap:15px;
    margin-bottom:20px;
}

select{
    padding:10px;
}

button{
    padding:10px 20px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    font-weight:bold;
}

.submit-btn{
    background:#22d646;
}

.verdict{
    margin-top:20px;
    padding:15px;
    border-radius:10px;
    background:#2a2e3a;
}

</style>

</head>

<body>

<div class="container">

<h1>{{.Problem.Title}}</h1>

<div class="controls">

<select id="language">

<option value="cpp">
    C++
</option>

<option value="python">
    Python
</option>

<option value="go">
    Go
</option>

</select>

<button
    class="submit-btn"
    onclick="submitCode()"
>
    Submit
</button>

</div>

<div id="editor"></div>

<div
    id="verdict"
    class="verdict"
>
    Verdict: Waiting...
</div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs/loader.min.js"></script>

<script>

require.config({
    paths: {
        vs:
        "https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs"
    }
});

let editor;

require(["vs/editor/editor.main"], function(){

    editor = monaco.editor.create(
        document.getElementById("editor"),
        {
            value:
`#include <bits/stdc++.h>
using namespace std;

int main(){

    return 0;
}
`,
            language:"cpp",
            theme:"vs-dark",
            automaticLayout:true
        }
    );

});

async function submitCode(){

    const code =
        editor.getValue();

    const language =
        document.getElementById("language").value;

    const verdict =
        document.getElementById("verdict");

    verdict.innerText =
        "Judging...";

    const res =
        await fetch(
            "/api/judge",
            {
                method:"POST",

                headers:{
                    "Content-Type":
                    "application/json"
                },

                body:JSON.stringify({
                    problem_id:
                        {{.Problem.ID}},
                    code,
                    language
                })
            }
        );

    const data =
        await res.json();

    verdict.innerText =
        "Verdict: " +
        data.verdict;
}

</script>

</body>
</html>