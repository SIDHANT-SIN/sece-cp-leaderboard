<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maintainer Dashboard</title>
    <style>
        body {
            background: #181a20;
            color: #eaeaea;
            font-family: 'Segoe UI', 'Roboto', 'Arial', sans-serif;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 1100px;
            margin: 40px auto;
            background: #23272f;
            border-radius: 18px;
            box-shadow: 0 4px 32px #000a;
            padding: 32px;
        }
        h1 {
            text-align: center;
            margin-top: 32px;
            font-size: 2.5rem;
            letter-spacing: 2px;
            color: #b347ff;
            text-shadow: 0 0 15px rgba(179, 71, 255, 0.5);
            background: linear-gradient(90deg, #9333ff, #c44dff);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .menu {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 32px 0;
        }
        .menu a {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 30px 20px;
            background: #2a2e3a;
            text-decoration: none;
            border-radius: 12px;
            font-weight: bold;
            transition: all 0.3s ease;
            text-align: center;
            min-height: 120px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }
        .menu a::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, #9333ff, #c44dff);
        }
        .menu a {
            color: #c44dff;
            font-size: 1.2rem;
        }
        .menu a:hover {
            background: #32363f;
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }
        .menu a::after {
            content: '';
            font-family: 'Segoe UI', sans-serif;
            font-size: 2.5rem;
            opacity: 0.1;
            position: absolute;
            bottom: 10px;
            right: 10px;
        }
        .menu a:nth-child(1)::after {
            content: '👤';
        }
        .menu a:nth-child(2)::after {
            content: '💻';
        }
        .menu a:nth-child(3)::after {
            content: '🔙';
        }
        .button-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 30px auto;
            flex-wrap: wrap;
        }
        .refresh-btn {
            width: 300px;
            padding: 16px;
            background: linear-gradient(145deg, #1eaf10, #22d646);
            color: rgb(0, 0, 0);
            border: none;
            border-radius: 12px;
            font-weight: bold;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(34, 214, 70, 0.3);
        }
        .refresh-btn:hover {
            background: linear-gradient(145deg, #22d646, #1eaf10);
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(34, 214, 70, 0.4);
        }
            .api-btn {
            width: 300px;
            padding: 16px;
            background: linear-gradient(145deg, #00e1ff, #00e1ff);
            color: rgb(0, 0, 0);
            border: none;
            border-radius: 12px;
            font-weight: bold;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(34, 157, 214, 0.72);
        }
        .api-btn:hover {
            background: linear-gradient(145deg, #00e1ff, #00e1ff);
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(34, 157, 214, 0.72);
        }

     
        .error {
            background: rgba(255, 59, 59, 0.1);
            color: #ff0000;
            padding: 12px;
            border-radius: 8px;
            margin: 20px 0;
            text-align: center;
        }
.cf-status {
     display: flex;
            justify-content: center;
            gap: 20px;
            margin: 30px auto;
            flex-wrap: wrap;
    margin-top: 15px auto;
    padding: 20px 32px;
    border-radius: 6px;
    background: #777;
    color: black;
    font-weight: 500;
    font-size: 20px;
    max-width: fit-content;
    transition: all 0.3s ease;
}

.cf-status.loading {
    background: #9e9e9e;
}

.cf-status.success {
    background: #4CAF50;
}

.cf-status.error {
    background: #f44336;
    color: white
}
    </style>
</head>
<body>
    <div class="container">
        <h1>Maintainer Dashboard</h1>
        <div class="menu">
            <a href="/maintainer/users"><span style="font-size: 1.8rem; margin-bottom: 10px;">👤</span> Manage Past Users</a>
            <a href="/maintainer/icpc_pyq"><span style="font-size: 1.8rem; margin-bottom: 10px;">💻</span> Manage ICPC Questions</a>
            <a href="/admin"><span style="font-size: 1.8rem; margin-bottom: 10px;">🔙</span> Back to Admin</a>
        </div>
        
    <div class="button-container">
    
    <form action="/maintainer/refresh_rating" method="post" style="margin: 0;">
        <button type="submit" class="refresh-btn">
            Refresh All Past User Rating
        </button>
    </form>

   <button type="button" class="api-btn" onclick="checkCFAPI()">
    Check Codeforces API
</button>

   {{if .error}}
            <div class="error">{{.error}}</div>
        {{end}}

</div>

<div id="cf-status" class="cf-status">
    API status: Unchecked
</div>

<script>
async function checkCFAPI() {
    const el = document.getElementById("cf-status");

    try {
        el.innerText = "Checking Codeforces API...";
        el.className = "cf-status loading";

        const res = await fetch("/admin/check_cf_api", {
            method: "POST"
        });

        const text = await res.text();   // ✅ must be defined BEFORE use

        console.log("RAW RESPONSE:", text);

        const data = JSON.parse(text);    // safer than res.json() for debugging

        if (data.status === "success") {
            el.className = "cf-status success";
            el.innerText = data.message;
        } else {
            el.className = "cf-status error";
            el.innerText = data.message;
        }

    } catch (err) {
        console.log("ERROR:", err);
        el.className = "cf-status error";
        el.innerText = "Request failed";
    }
}
</script>
        
     
    </div>
</body>
</html>