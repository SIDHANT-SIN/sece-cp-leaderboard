{{ define "past_leaderboard.tmpl" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Past_Leaderboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>




 :root{
    --bg:        #14161c;
    --panel:     #1c1f27;
    --panel-2:   #20232c;
    --border:    #2a2e38;
    --border-lt: #343946;
    --text:      #eaeaea;
    --text-dim:  #8a909c;
    --cyan:      #00e1ff;
    --cyan-dim:  rgba(0,225,255,0.12);
    --amber:     #ffb300;
    --green:     #3ddc97;
    --red:       #ff5c6c;
    --mono: 'JetBrains Mono', 'Roboto Mono', 'Consolas', monospace;
    --sans: 'Segoe UI', 'Roboto', 'Inter', Arial, sans-serif;
  }

  *{ box-sizing:border-box; }


  .page-head2{
    text-align:center;
    margin-bottom:4px;
  }

  .page-head2 .eyebrow2{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0 0 10px;
  }

  .page-head2 .eyebrow2 a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .page-head2 .eyebrow2 a:hover {
    color: var(--cyan);
  }

  .page-head2 .eyebrow2 .sep2 {
    color: var(--border-lt);
  }

  .page-head2 .eyebrow2 .current2 {
    color: var(--amber);
    letter-spacing: 3px;
  }



 .he1{
    font-size:2.1rem;
    font-weight:700;
    letter-spacing:0.5px;
    margin:0;
    color:var(--text);
  }

  .he1 .accent2{ color:var(--cyan); }

  .page-head2 .sub2{
    margin:10px 0 0;
    color:var(--text-dim);
    font-size:14px;
  }









        body {
            background-color: #14161c; 
            background-image: 
              radial-gradient(circle at 15% 0%, rgba(0,225,255,0.05), transparent 45%),
              radial-gradient(circle at 85% 20%, rgba(255,179,0,0.04), transparent 40%);
            color: #eaeaea;
            font-family: 'Segoe UI', 'Roboto', 'Arial', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        h1 {
            text-align: center;
            margin-top: 32px;
            font-size: 2.5rem;
            letter-spacing: 2px;
            color: #00e1ff;
            text-shadow: 0 2px 16px #00e1ff33;
        }
        @keyframes gradient-slide {
            0% { background-position: -100% 0%; }
            100% { background-position: 200% 0%; }
        }
        .leaderboard-container {
            max-width: 100vw;
            margin: 40px auto;
            background: #23272f;
            border-radius: 18px;
            box-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
            padding: 32px 32px 24px 16px;
        }
        th, td {
            padding: 13px 18px;
            text-align: center;
            border-bottom: 1px solid #2c2f36;
            min-width: 120px;
        }
        th {
            color: #00e1ff;
            font-size: 13.5px;
            font-weight: 600;
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }
        th.rank-col, td.rank-col,
        th.user-col, td.user-col,
        th.points-col, td.points-col {
            background: #181a20;
        }
        th.rank-col, td.rank-col {
            width: 70px;
            min-width: 70px;
            max-width: 70px;
        }
        th.user-col, td.user-col {
            width: 250px;
            min-width: 250px;
            max-width: 250px;
        }
        th.points-col, td.points-col {
            width: 120px;
            min-width: 120px;
            max-width: 120px;
        }
        table {
            width: auto;
            min-width: 1200px;
            border-collapse: separate;
            border-spacing: 0;
            background: none;
            margin-left: 0;
        }
.page-head {
    text-align: center;
    margin: 28px 0 8px;
}

.eyebrow {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
}

.eyebrow a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s ease;
}

.eyebrow a:hover {
    color: #00e1ff;
}

.eyebrow a svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
}

.eyebrow .sep {
    color: #3a3f48;
}

.eyebrow .current {
    color: #00e1ff;
    text-shadow: 0 2px 16px #00e1ff33;
}

.top-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin: 6px 0 8px;
}

.dropdown-wrapper {
    position: relative;
    display: inline-block;
}

.dropdown-wrapper::after {
    content: "▾";
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #00e1ff;
    pointer-events: none;
    font-size: 13px;
}

.batch-dropdown {
    background: #181a20;
    color: #00e1ff;

    border: 1px solid #2a2e38;
    border-radius: 7px;

    width: 145px;

    padding: 9px 36px 9px 14px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.3px;

    cursor: pointer;
    outline: none;

    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;

    transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.batch-dropdown:hover {
    border-color: #00e1ff;
}

.batch-dropdown:focus {
    border-color: #00e1ff;
    box-shadow: 0 0 0 3px rgba(0, 225, 255, 0.15);
}
        .scroll-x {
            overflow-x: auto;
            padding-bottom: 8px;
            scrollbar-width: thin;
            scrollbar-color: #23272f #181a20;
        }
        .scroll-x::-webkit-scrollbar {
            height: 6px;
            background: transparent;
        }
        .scroll-x::-webkit-scrollbar-thumb {
            background: #23272f;
            border-radius: 4px;
        }
        .scroll-x::-webkit-scrollbar-track {
            background: transparent;
        }
        tr:nth-child(even) {
            background: #20232a;
        }
        tr:hover {
            background: #282c34;
        }
        footer {
            margin-top: auto !important;
            padding: 18px 0 10px 0;
            text-align: center;
            width: 100%;
        }
        @media (max-width: 700px) {
            .leaderboard-container {
                padding: 20px 12px 18px 12px;
                border-radius: 14px;
            }
            table {
                min-width: 640px;
            }
            th, td { 
                padding: 10px 10px; 
                font-size: 0.88rem; 
                min-width: 100px;
                white-space: nowrap;
            }
            h1 { 
                font-size: 1.5rem; 
            }
            th.rank-col, td.rank-col { width: 42px; min-width: 42px; max-width: 42px; }
            th.user-col, td.user-col {
                width: 165px;
                min-width: 165px;
                max-width: 165px;
                white-space: normal;
            }
            th.points-col, td.points-col { width: 80px; min-width: 80px; max-width: 80px; }
            .eyebrow { font-size: 11px; gap: 7px; }
            .batch-dropdown { font-size: 13px; padding: 8px 32px 8px 12px; }
        }
    </style>
</head>
<body>
    <h1>SECE CP LEADERBOARD</h1>
