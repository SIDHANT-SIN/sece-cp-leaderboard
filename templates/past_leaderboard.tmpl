 <div class="page-head2">
    <div class="eyebrow2">
      <a href="/leaderboard">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="m15 18-6-6 6-6"/></svg>
       Go to Leaderboard
      </a>
      <span class="sep2">/</span>
      <span class="current2">Batch Wise Ratings</span>
    </div>
    
    <h1><div class ="he1">
    Past <span class="accent2">Batch Ratings</span>
    </div>
    </h1>
  </div>
  

<div class="top-actions">
    <form method="GET" action="/past_leaderboard">
    <div class="dropdown-wrapper">
        <select name="batch" onchange="this.form.submit()" class="batch-dropdown">

            <option value="2023"
                {{if eq .selectedBatch "2023"}}selected{{end}}>
                2023 - 2027
            </option>

            <option value="2024"
                {{if eq .selectedBatch "2024"}}selected{{end}}>
                2024 - 2028
            </option>

        </select>
        </div>
    </form>
</div>

    <div class="leaderboard-container">
        <div class="scroll-x">
            <table>
        <tr>
    <th class="rank-col">Rank</th>
    <th class="user-col">User</th>
    <th>Title</th>
    <th>Current Rating</th>
    <th>Maximum Rating</th>
</tr>
                
        {{ range .users }}
<tr>
    <td class="rank-col">{{ .rank }}</td>

    <td class="user-col">
        {{ .display_name }}
        <a href="https://codeforces.com/profile/{{ .handle }}"
           target="_blank"
           style="color:#00e1ff;text-decoration:underline;">
            ({{ .handle }})
        </a>
    </td>

    <td><span style="color:#9aa3b2;font-weight:500;">{{ .title }}</span></td>

    <td>
        <span style="color:#00ffb3;">
            {{ .current_rating }}
        </span>
    </td>

    <td>
        <span style="color:#ffb300;">
            {{ .max_rating }}
        </span>
    </td>
</tr>
{{ end }}
            </table>
        </div>
    </div>

    <footer>
        <div style="display: flex; justify-content: center; align-items: center; gap: 18px;">
            <a href="https://github.com/je573r/sece-cp-leaderboard/issues" target="_blank" style="display:inline-block;">
                <img src="https://img.shields.io/badge/report%20a%20problem-%F0%9F%90%9E%20GitHub-black?style=social&labelColor=23272f&color=23272f" alt="Report a problem" style="vertical-align: middle;"/>
            </a>
            <a href="https://github.com/je573r/sece-cp-leaderboard/stargazers" target="_blank" style="display:inline-block;">
                <img src="https://img.shields.io/badge/Star%20this%20repo-%E2%AD%90%EF%B8%8F%20GitHub-black?style=social&labelColor=23272f&color=23272f" alt="Star this repo on GitHub" style="vertical-align: middle;"/>
            </a>
        </div>
                  <p style="text-align:center; margin-top:12px; color:#888; font-size:14px;">
        &copy; 2025 Developed by Sidhant & Ayush
    </p>
    </footer>
</body>
</html>
