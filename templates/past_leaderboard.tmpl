      <div class="eyebrow">
        <a href="/leaderboard">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="m15 18-6-6 6-6"/></svg>
          <div style ="font-size: 15px;">Go to Leaderboard</div>
        </a>
        <span class="sep">/</span>
        <span class="current" style="color: #ffb300; text-shadow: 0 2px 16px rgba(3, 2, 0, 0.25);  font-size: 15px;">Previous Batch Rankings</span>
      </div>
