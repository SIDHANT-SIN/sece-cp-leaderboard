{{ define "past_leaderboard.tmpl" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Past_Leaderboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            background: #181a20;
            color: #eaeaea;
            font-family: 'Segoe UI', 'Roboto', 'Arial', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        h1 {
            text-align: center;
            margin-top: 32px;
            font-size: 2.5rem;
            letter-spacing: 2px;
            color: #00e1ff;
            text-shadow: 0 2px 16px #00e1ff33;
        }
        @keyframes gradient-slide {
            0% { background-position: -100% 0%; }
            100% { background-position: 200% 0%; }
        }
        .leaderboard-container {
            max-width: 100vw;
            margin: 40px auto;
            background: #23272f;
            border-radius: 18px;
            box-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
            padding: 32px 32px 24px 16px;
        }
        th, td {
            padding: 12px 18px;
            text-align: center;
            border-bottom: 1px solid #2c2f36;
            min-width: 120px;
        }
        th.rank-col, td.rank-col,
        th.user-col, td.user-col,
        th.points-col, td.points-col {
            background: #181a20;
        }
        th.rank-col, td.rank-col {
            width: 70px;
            min-width: 70px;
            max-width: 70px;
        }
        th.user-col, td.user-col {
            width: 250px;
            min-width: 250px;
            max-width: 250px;
        }
        th.points-col, td.points-col {
            width: 120px;
            min-width: 120px;
            max-width: 120px;
        }
        table {
            width: auto;
            min-width: 1200px;
            border-collapse: separate;
            border-spacing: 0;
            background: none;
            margin-left: 0;
        }
        .top-actions {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin: 16px 0;
        }
        .btn {
            display: inline-block;
            padding: 14px 22px;
            color: black;
            background: #00e1ff;
            border: 1px solid #00e1ff;
            border-radius: 6px;
            font-size: 20px;
            font-weight: 500;
            text-decoration: none;
            transition: 0.2s ease;
        }
        .btn:hover {
            background: rgba(0, 225, 255, 0.08);
            color: white;
        }
        .btn:active {
            transform: scale(0.98);
        }
        .go-btn {
    margin-left: 12px;
    padding: 14px 18px;
    border-radius: 8px;
    font-size: 20px;

  border: 1px solid #00e1ff;
    background: #23272f;
    color: #00e1ff;

    cursor: pointer;
    font-weight: 500;

    transition: 0.2s ease;
}

.go-btn:hover {
    border-color: #11b9d2;
    box-shadow: 0 0 0 2px rgba(63, 178, 255, 0.2);
}
.batch-dropdown {
    background: #23272f;
    color: #00e1ff;

    border: 1px solid #00e1ff;
    border-radius: 8px;

    padding: 14px 44px 12px 16px; /* extra right space for arrow */
    font-size: 22px;

    cursor: pointer;
    outline: none;

    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;

    position: relative;

    transition: all 0.2s ease;
}

.dropdown-wrapper {
    position: relative;
    display: inline-block;
}

.dropdown-wrapper::after {
    content: "▾";
    position: absolute;

    right: 14px;
    top: 50%;
    transform: translateY(-50%);

    color: #00e1ff;
    pointer-events: none;

    font-size: 16px;
}

.batch-dropdown:hover {
    box-shadow: 0 0 0 3px rgba(0, 225, 255, 0.15);
}

.batch-dropdown:focus {
    border-color: #00e1ff;
    box-shadow: 0 0 0 3px rgba(0, 225, 255, 0.25);
}
        .scroll-x {
            overflow-x: auto;
            padding-bottom: 8px;
            scrollbar-width: thin;
            scrollbar-color: #23272f #181a20;
        }
        .scroll-x::-webkit-scrollbar {
            height: 6px;
            background: transparent;
        }
        .scroll-x::-webkit-scrollbar-thumb {
            background: #23272f;
            border-radius: 4px;
        }
        .scroll-x::-webkit-scrollbar-track {
            background: transparent;
        }
        tr:nth-child(even) {
            background: #20232a;
        }
        tr:hover {
            background: #282c34;
        }
        footer {
            margin-top: auto !important;
            padding: 18px 0 10px 0;
            text-align: center;
            width: 100%;
        }
        @media (max-width: 700px) {
            th, td { 
                padding: 8px 6px; 
                font-size: 0.95rem; 
            }
            h1 { 
                font-size: 1.5rem; 
            }
            th.rank-col, td.rank-col { width: 48px; min-width: 48px; max-width: 48px; }
            th.user-col, td.user-col { width: 120px; min-width: 120px; max-width: 120px; }
            th.points-col, td.points-col { width: 80px; min-width: 80px; max-width: 80px; }
        }
    </style>
</head>
<body>
    <h1>SECE CP LEADERBOARD</h1>
    <h2 style="text-align:center;color:#00e1ff;">Previous Batch Rankings</h2>
    
<div class="top-actions">
    <form method="GET" action="/past_leaderboard">
    <div class="dropdown-wrapper">
        <select name="batch" onchange="this.form.submit()" class="batch-dropdown">

            <option value="2023"
                {{if eq .selectedBatch "2023"}}selected{{end}}>
                2023 - 2027
            </option>

            <option value="2024"
                {{if eq .selectedBatch "2024"}}selected{{end}}>
                2024 - 2028
            </option>

        </select>
        </div>
    </form>
        <button type="button"
                onclick="window.location.href='/leaderboard'"
                class="go-btn">
            Back to Leaderboard
        </button>
</div>

    <div class="leaderboard-container">
        <div class="scroll-x">
            <table>
        <tr>
    <th class="rank-col">Rank</th>
    <th class="user-col">User</th>
    <th>Title</th>
    <th>Current Rating</th>
    <th>Maximum Rating</th>
</tr>
                
        {{ range .users }}
<tr>
    <td class="rank-col">{{ .rank }}</td>

    <td class="user-col">
        {{ .display_name }}
        <a href="https://codeforces.com/profile/{{ .handle }}"
           target="_blank"
           style="color:#00e1ff;text-decoration:underline;">
            ({{ .handle }})
        </a>
    </td>

    <td>{{ .title }}</td>

    <td>
        <span style="color:#00ffb3;">
            {{ .current_rating }}
        </span>
    </td>

    <td>
        <span style="color:#ffb300;">
            {{ .max_rating }}
        </span>
    </td>
</tr>
{{ end }}
            </table>
        </div>
    </div>

    <footer>
        <div style="display: flex; justify-content: center; align-items: center; gap: 18px;">
            <a href="https://github.com/je573r/sece-cp-leaderboard/issues" target="_blank" style="display:inline-block;">
                <img src="https://img.shields.io/badge/report%20a%20problem-%F0%9F%90%9E%20GitHub-black?style=social&labelColor=23272f&color=23272f" alt="Report a problem" style="vertical-align: middle;"/>
            </a>
            <a href="https://github.com/je573r/sece-cp-leaderboard/stargazers" target="_blank" style="display:inline-block;">
                <img src="https://img.shields.io/badge/Star%20this%20repo-%E2%AD%90%EF%B8%8F%20GitHub-black?style=social&labelColor=23272f&color=23272f" alt="Star this repo on GitHub" style="vertical-align: middle;"/>
            </a>
        </div>
    </footer>
</body>
</html>
{{ end }}