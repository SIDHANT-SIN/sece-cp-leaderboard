<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>{{.Problem.Title}}</title>

<style>

body{
    background:#181a20;
    color:#eaeaea;
    font-family:'Segoe UI','Roboto','Arial',sans-serif;
    margin:0;
    padding:0;
}

.container{
    max-width:1100px;
    margin:40px auto;
    background:#23272f;
    border-radius:18px;
    box-shadow:0 4px 32px #000a;
    padding:32px;
}

h1{
    text-align:center;
    margin-bottom:25px;
    font-size:2.4rem;

    background:linear-gradient(
        90deg,
        #9333ff,
        #c44dff
    );

    -webkit-background-clip:text;
    background-clip:text;
    -webkit-text-fill-color:transparent;
}

.meta{
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
    margin-bottom:30px;
}

.meta-box{
    background:#2a2e3a;
    padding:12px 20px;
    border-radius:10px;
    font-weight:bold;
}

.section{
    margin-top:30px;
}

.section h2{
    color:#c44dff;
    margin-bottom:12px;
}

.section-content{
    background:#2a2e3a;
    padding:18px;
    border-radius:12px;
    line-height:1.7;
    white-space:pre-wrap;
}

.samples{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
    margin-top:20px;
}

.sample-box{
    background:#2a2e3a;
    border-radius:12px;
    overflow:hidden;
}

.sample-header{
    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:12px 15px;

    background:#32363f;

    font-weight:bold;
}

.copy-btn{
    background:#9333ff;
    color:white;

    border:none;

    padding:8px 14px;

    border-radius:8px;

    cursor:pointer;

    transition:.3s;
}

.copy-btn:hover{
    background:#a855f7;
}

.sample-content{
    padding:18px;
    white-space:pre-wrap;
    font-family:monospace;
    overflow-x:auto;
}

.button-container{
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
    margin-top:40px;
}

.solve-btn{
    display:inline-block;

    width:260px;

    padding:16px;

    text-align:center;

    text-decoration:none;

    border-radius:12px;

    font-weight:bold;

    transition:.3s;
}

.solve-here{
    background:linear-gradient(
        145deg,
        #1eaf10,
        #22d646
    );

    color:black;
}

.solve-here:hover{
    transform:translateY(-3px);
}

.solve-external{
    background:linear-gradient(
        145deg,
        #00e1ff,
        #00c4ff
    );

    color:black;
}

.solve-external:hover{
    transform:translateY(-3px);
}

.back-btn{
    display:inline-block;

    margin-bottom:20px;

    text-decoration:none;

    color:#c44dff;

    font-weight:bold;
}

@media(max-width:800px){

    .samples{
        grid-template-columns:1fr;
    }

}

</style>
</head>
<body>

<div class="container">

<a href="/problems" class="back-btn">
    ← Back To Problems
</a>

<h1>{{.Problem.Title}}</h1>

<div class="meta">

<div class="meta-item">
    <strong>Time Limit:</strong> {{.Problem.TimeLimit}} sec
</div>

<div class="meta-item">
    <strong>Memory Limit:</strong> {{.Problem.MemoryLimit}} MB
</div>

</div>

<div class="section">
    <h2>Statement</h2>
    <div class="section-content">
{{.Problem.Statement}}
    </div>
</div>

<div class="section">
    <h2>Input</h2>
    <div class="section-content">
{{.Problem.InputDesc}}
    </div>
</div>

<div class="section">
    <h2>Output</h2>
    <div class="section-content">
{{.Problem.OutputDesc}}
    </div>
</div>

{{if .Problem.Constraints}}
<div class="section">
    <h2>Constraints</h2>
    <div class="section-content">
{{.Problem.Constraints}}
    </div>
</div>
{{end}}

<div class="section">

    <h2>Samples</h2>

    <div class="samples">

        <div class="sample-box">

            <div class="sample-header">

                Sample Input

                <button
                    class="copy-btn"
                    onclick="copyText('sample-input')"
                >
                    Copy
                </button>

            </div>

            <div
                id="sample-input"
                class="sample-content"
            >
{{.Problem.SampleInput}}
            </div>

        </div>

        <div class="sample-box">

            <div class="sample-header">

                Sample Output

                <button
                    class="copy-btn"
                    onclick="copyText('sample-output')"
                >
                    Copy
                </button>

            </div>

            <div
                id="sample-output"
                class="sample-content"
            >
{{.Problem.SampleOutput}}
            </div>

        </div>

    </div>

</div>

{{if .Problem.Explanation}}

<div class="section">

    <h2>Explanation</h2>

    <div class="section-content">
{{.Problem.Explanation}}
    </div>

</div>

{{end}}

<div class="button-container">

    <a
        href="/problems/{{.Problem.ID}}/solve"
        class="solve-btn solve-here"
    >
        Solve Here
    </a>

    <a
        href="{{.Problem.ExternalURL}}"
        target="_blank"
        class="solve-btn solve-external"
    >
        Solve On CodeChef
    </a>

</div>

</div>

<script>

function copyText(id){

    const text =
        document.getElementById(id).innerText;

    navigator.clipboard.writeText(text);

}

</script>

</body>
</html>