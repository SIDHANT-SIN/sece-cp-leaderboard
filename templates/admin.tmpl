<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard</title>

<style>

  :root{
    --bg:        #14161c;
    --panel:     #1c1f27;
    --panel-2:   #20232c;
    --border:    #2a2e38;
    --border-lt: #343946;
    --text:      #eaeaea;
    --text-dim:  #8a909c;
    --cyan:      #00e1ff;
    --cyan-dim:  rgba(0,225,255,0.12);
    --purple:    #b347ff;
    --purple-2:  #c44dff;
    --purple-dim: rgba(179,71,255,0.12);
    --amber:     #ffb300;
    --green:     #3ddc97;
    --red:       #ff5c6c;
    --mono: 'JetBrains Mono', 'Roboto Mono', 'Consolas', monospace;
    --sans: 'Segoe UI', 'Roboto', 'Inter', Arial, sans-serif;
  }

  *{ box-sizing:border-box; }

  body{
    background:var(--bg);
    background-image:
      radial-gradient(circle at 15% 0%, rgba(179,71,255,0.07), transparent 45%),
      radial-gradient(circle at 85% 15%, rgba(0,225,255,0.05), transparent 40%),
      radial-gradient(circle at 50% 100%, rgba(255,179,0,0.03), transparent 50%);
    color:var(--text);
    font-family:var(--sans);
    margin:0;
    padding:0;
    min-height:100vh;
  }

  .container{
    max-width:1100px;
    margin:0 auto;
    padding:48px 24px 64px;
  }

  /* ---------- Header ---------- */

  .page-head{
    text-align:center;
    margin-bottom:40px;
  }

  .page-head .eyebrow{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    font-family:var(--mono);
    font-size:12px;
    letter-spacing:2px;
    text-transform:uppercase;
    color:var(--text-dim);
    margin:0 0 14px;
  }

  .page-head .eyebrow .dot{
    width:7px;
    height:7px;
    border-radius:50%;
    background:var(--green);
    box-shadow:0 0 8px var(--green);
  }

  h1{
    font-size:2.3rem;
    font-weight:700;
    letter-spacing:0.5px;
    margin:0;
    color:var(--text);
  }

  h1 .accent{
    background:linear-gradient(90deg, var(--purple), var(--purple-2));
    -webkit-background-clip:text;
    background-clip:text;
    -webkit-text-fill-color:transparent;
  }

  /* ---------- Nav menu ---------- */

  .menu{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(250px, 1fr));
    gap:18px;
    margin:36px 0;
  }

  .menu a{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:10px;
    padding:28px 20px;
    min-height:120px;
    background:var(--panel);
    border:1px solid var(--border);
    border-radius:14px;
    text-decoration:none;
    color:var(--text);
    font-weight:600;
    font-size:1.05rem;
    text-align:center;
    position:relative;
    overflow:hidden;
    transition:border-color 0.2s ease, transform 0.15s ease, background 0.2s ease;
  }

  .menu a::before{
    content:'';
    position:absolute;
    top:0; left:0;
    width:100%;
    height:3px;
    background:linear-gradient(90deg, var(--purple), var(--cyan));
    opacity:0.8;
  }

  .menu a .menu-ico{
    font-size:1.7rem;
    opacity:0.9;
  }

  .menu a:hover{
    background:var(--panel-2);
    border-color:var(--border-lt);
    transform:translateY(-3px);
  }

  /* ---------- Action buttons ---------- */

  .button-row{
    display:flex;
    justify-content:center;
    gap:16px;
    margin:30px auto;
    flex-wrap:wrap;
  }

  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    width:280px;
    padding:15px 18px;
    border-radius:10px;
    font-weight:600;
    font-size:1rem;
    text-align:center;
    text-decoration:none;
    cursor:pointer;
    border:1px solid transparent;
    transition:transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .btn:active{ transform:scale(0.97); }

  .btn-primary{
    background:var(--green);
    color:#0b0d11;
    box-shadow:0 4px 18px rgba(61,220,151,0.25);
  }
  .btn-primary:hover{
    box-shadow:0 6px 22px rgba(61,220,151,0.4);
    transform:translateY(-2px);
  }
  .btn-primary:disabled{
    opacity:0.55;
    cursor:not-allowed;
    transform:none;
  }

  .btn-accent{
    background:transparent;
    color:var(--cyan);
    border:1px solid rgba(0,225,255,0.4);
  }
  .btn-accent:hover{
    background:var(--cyan-dim);
    transform:translateY(-2px);
  }

  .btn-danger{
    width:240px;
    background:transparent;
    color:var(--red);
    border:1px solid rgba(255,92,108,0.4);
  }
  .btn-danger:hover{
    background:rgba(255,92,108,0.1);
    transform:translateY(-2px);
  }
  .btn-danger:disabled{
    opacity:0.55;
    cursor:not-allowed;
    transform:none;
  }

  /* ---------- Error ---------- */

  .error-box{
    display:flex;
    align-items:flex-start;
    gap:12px;
    background:rgba(255,92,108,0.08);
    border:1px solid rgba(255,92,108,0.35);
    color:var(--red);
    border-radius:10px;
    padding:16px 18px;
    margin:24px auto;
    max-width:600px;
    font-size:14.5px;
  }

  .error-box .ico{
    font-family:var(--mono);
    font-weight:700;
    border:1px solid var(--red);
    border-radius:50%;
    width:20px; height:20px;
    display:flex; align-items:center; justify-content:center;
    font-size:12px;
    flex-shrink:0;
    margin-top:1px;
  }

  /* ---------- CF status pill ---------- */

  .cf-status{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    margin:24px auto 0;
    padding:14px 28px;
    border-radius:999px;
    background:var(--panel);
    border:1px solid var(--border);
    color:var(--text-dim);
    font-family:var(--mono);
    font-size:13.5px;
    font-weight:600;
    max-width:fit-content;
    transition:border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .cf-status::before{
    content:'';
    width:8px; height:8px;
    border-radius:50%;
    background:var(--border-lt);
    flex-shrink:0;
  }
  .cf-status.loading{ color:var(--amber); border-color:rgba(255,179,0,0.35); }
  .cf-status.loading::before{ background:var(--amber); box-shadow:0 0 8px var(--amber); }
  .cf-status.success{ color:var(--green); border-color:rgba(61,220,151,0.35); background:rgba(61,220,151,0.06); }
  .cf-status.success::before{ background:var(--green); box-shadow:0 0 8px var(--green); }
  .cf-status.error{ color:var(--red); border-color:rgba(255,92,108,0.35); background:rgba(255,92,108,0.06); }
  .cf-status.error::before{ background:var(--red); box-shadow:0 0 8px var(--red); }

  /* ---------- Progress card ---------- */

  .progress-card{
    max-width:600px;
    margin:30px auto;
    background:var(--panel);
    border:1px solid var(--border);
    border-radius:14px;
    padding:26px 28px;
    text-align:center;
    position:relative;
    overflow:hidden;
  }

  .progress-card::before{
    content:'';
    position:absolute;
    top:0; left:0;
    width:100%; height:3px;
    background:linear-gradient(90deg, var(--purple), var(--purple-2), var(--cyan));
  }

  .progress-card h3{
    margin:4px 0 18px;
    font-family:var(--mono);
    font-size:12px;
    letter-spacing:2px;
    text-transform:uppercase;
    color:var(--purple-2);
  }

  .progress-status-text{
    margin-bottom:14px;
    font-weight:600;
    font-size:0.95rem;
    color:var(--text);
  }

  .progress-bar-track{
    width:100%;
    height:12px;
    background:var(--bg);
    border:1px solid var(--border);
    border-radius:999px;
    overflow:hidden;
    margin-bottom:22px;
  }

  .progress-bar-fill{
    width:0%;
    height:100%;
    border-radius:999px;
    background:linear-gradient(90deg, var(--purple), var(--purple-2));
    box-shadow:0 0 10px rgba(196,77,255,0.5);
    transition:width 0.35s ease;
  }

  .failures-panel{
    display:none;
    background:rgba(255,92,108,0.08);
    border:1px solid rgba(255,92,108,0.25);
    color:var(--red);
    padding:14px 16px;
    border-radius:10px;
    text-align:left;
    font-size:0.85rem;
    margin-bottom:20px;
    font-family:var(--mono);
    max-height:150px;
    overflow-y:auto;
  }

  /* ---------- Logs section ---------- */

  .logs-head{
    text-align:center;
    margin-top:52px;
    margin-bottom:20px;
  }

  .logs-head .eyebrow{
    font-family:var(--mono);
    font-size:11.5px;
    letter-spacing:2px;
    text-transform:uppercase;
    color:var(--text-dim);
    margin-bottom:6px;
  }

  .logs-head h2{
    font-size:1.4rem;
    font-weight:700;
    color:var(--text);
    margin:0;
  }

  .logs-head h2 .accent{ color:var(--purple-2); }

  .logs-card{
    width:100%;
    margin:0 auto;
    background:var(--panel);
    border:1px solid var(--border);
    border-radius:14px;
    overflow-x:auto;
  }

  .logs-table{
    width:100%;
    border-collapse:collapse;
    text-align:left;
    min-width:700px;
  }

  .logs-table thead tr{
    border-bottom:1px solid var(--border);
    background:linear-gradient(180deg, rgba(255,255,255,0.015), transparent);
  }

  /* ============================================================
     TABLE TEXT SIZE CONTROLS — change the numbers below to resize
     every piece of text inside the Recent Refresh Logs table.
     ============================================================ */

  .logs-table th{
    padding:16px 18px;
    font-family:var(--mono);
    font-size:13px;          /* column header text size */
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:1.2px;
    color:var(--text-dim);
  }

  .logs-table tbody tr{
    border-bottom:1px solid var(--border);
    transition:background 0.15s ease;
  }

  .logs-table tbody tr:last-child{ border-bottom:none; }

  .logs-table tbody tr:hover{ background:var(--panel-2); }

  .logs-table td{ padding:14px 18px; }

  .job-id-cell{
    font-family:var(--mono);
    font-size:14.5px;        /* "Refresh Type" / job id column */
    color:var(--purple-2);
  }

  .progress-cell{ font-size:1.02rem; }   /* "Progress" column (e.g. 1 / 1) */

  .timestamp-cell{
    font-family:var(--mono);
    font-size:14px;          /* "Finished" and "Time Taken (sec)" columns */
    color:var(--text-dim);
  }

  .no-history{
    text-align:center;
    color:var(--text-dim);
    padding:50px 24px;
  }

  /* ---------- Badges ---------- */

  .badge{
    display:inline-block;
    padding:5px 10px;
    border-radius:6px;
    font-size:12.5px;        /* status badge text (Completed/Failed/etc.) */
    font-weight:700;
    letter-spacing:0.4px;
    text-transform:uppercase;
    font-family:var(--mono);
  }
  .badge-completed{ background:rgba(61,220,151,0.12); color:var(--green); border:1px solid rgba(61,220,151,0.3); }
  .badge-processing{ background:var(--cyan-dim); color:var(--cyan); border:1px solid rgba(0,225,255,0.3); }
  .badge-cancelled{ background:rgba(255,179,0,0.12); color:var(--amber); border:1px solid rgba(255,179,0,0.3); }
  .badge-failed{ background:rgba(255,92,108,0.12); color:var(--red); border:1px solid rgba(255,92,108,0.3); }

  .failed-box{
    font-size:0.76rem;
    color:var(--red);
    margin-top:6px;
    font-family:var(--mono);
    background:rgba(255,92,108,0.06);
    padding:5px 9px;
    border-radius:6px;
    border:1px solid rgba(255,92,108,0.15);
    display:block;
    word-break:break-all;
  }

  #refresh-limit::-webkit-outer-spin-button,
    #refresh-limit::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    /* Hide arrows in Firefox */
    #refresh-limit {
        -moz-appearance: textfield;
    }

  /* ---------- Footer ---------- */

  footer{
    margin-top:48px;
    text-align:center;
    color:var(--text-dim);
    font-size:13px;
  }


  /* ---------- Responsive ---------- */

  @media (max-width:700px){
    .container{ padding:32px 14px 48px; }
    h1{ font-size:1.7rem; }
    .btn{ width:100%; max-width:320px; }
    .btn-danger{ width:100%; max-width:240px; }
    .logs-table th, .logs-table td{ padding:10px 12px; font-size:0.9rem; }
    .logs-head h2{ font-size:1.2rem; }
  }

  /* ---------- Reduced motion ---------- */

  @media (prefers-reduced-motion: reduce){
    .menu a, .btn, .cf-status, .progress-bar-fill, .logs-table tbody tr{ transition:none; }
  }

</style>
</head>
<body>
<div class="container">

    <div class="page-head">
        <div class="eyebrow"><span class="dot"></span> Admin Console</div>
        <h1>Admin <span class="accent">Dashboard</span></h1>
    </div>

    <div class="menu">
        <a href="/admin/users"><span class="menu-ico">👤</span> Manage Users</a>
        <a href="/admin/contests"><span class="menu-ico">🏆</span> Manage Contests</a>
        <a href="/leaderboard"><span class="menu-ico">📊</span> View Leaderboard</a>
    </div>

  <div class="button-row">
        <div style="display: flex; gap: 10px; align-items: center; justify-content: center; flex-wrap: wrap;">
            <input type="number" id="refresh-limit" class="btn btn-accent" style="width: 180px; cursor: text; text-align: left; background: transparent; color: var(--text);" placeholder="Count of Contests" min="1">
            <button type="button" id="refresh-btn" class="btn btn-primary" onclick="startRefresh()" style="width: auto;">
                Refresh Results (default: all contests are refreshed)
            </button>
        </div>

        <button type="button" class="btn btn-accent" onclick="checkCFAPI()">
            Check Codeforces API
        </button>
    </div>

    {{if .error}}
        <div class="error-box">
            <span class="ico">!</span>
            <span>{{.error}}</span>
        </div>
    {{end}}

    <div id="progress-container" class="progress-card" style="display: none;">
        <h3>Refresh Status</h3>
        <div id="progress-text" class="progress-status-text">Updating: 0 / 0 contests finished</div>
        <div id="progress-bar-container" class="progress-bar-track">
            <div id="progress-bar-fill" class="progress-bar-fill"></div>
        </div>
        <div id="failures-list" class="failures-panel"></div>
        <button type="button" id="cancel-btn" class="btn btn-danger" onclick="cancelSync()">
            Cancel Refresh
        </button>
    </div>

    <div id="cf-status" class="cf-status">
        API status: Unchecked
    </div>

    <div class="logs-head">
        <div class="eyebrow">Sync History</div>
        <h2>Recent <span class="accent">Refresh Logs</span> ( Past 10 )</h2>
    </div>

    <div class="logs-card">
        {{if .history}}
            <table class="logs-table">
                <thead>
                    <tr>
                        <th>Refresh Type</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Finished</th>
                        <th>Time Taken (sec)</th>
                    </tr>
                </thead>
                <tbody>
                    {{range .history}}
                        <tr>
                            <td class="job-id-cell">{{.job_id}}</td>
                            <td>
                                {{if eq .status "completed"}}
                                    <span class="badge badge-completed">Completed</span>
                                {{else if eq .status "processing"}}
                                    <span class="badge badge-processing">Processing</span>
                                {{else if eq .status "cancelled"}}
                                    <span class="badge badge-cancelled">Cancelled</span>
                                {{else}}
                                    <span class="badge badge-failed">{{.status}}</span>
                                {{end}}
                            </td>
                            <td class="progress-cell">
                                <div>{{.successful_contests}} / {{.total_contests}}</div>
                                {{if .failed_contest_ids}}
                                    <div class="failed-box">
                                        ⚠️ Failed IDs: {{.failed_contest_ids}}
                                    </div>
                                {{end}}
                            </td>
                            <td class="timestamp-cell">{{.completed_at}}</td>
                            <td class="timestamp-cell">{{.started_at}}</td>
                        </tr>
                    {{end}}
                </tbody>
            </table>
        {{else}}
            <p class="no-history">No sync history found.</p>
        {{end}}
    </div>

    <footer>
        <p>&copy; 2025 Developed by Sidhant &amp; Ayush</p>
    </footer>

</div>

<script>
let isPolling = false;
let syncWasRunning = false; // Tracks if a sync cycle was active
let isCancelling = false;    // 🚀 NEW: Protects the UI state when aborting a job

window.addEventListener("DOMContentLoaded", () => {
    checkStatus();
});

async function checkStatus() {
    if (isPolling) return;
    isPolling = true;
    
    const btn = document.getElementById("refresh-btn");
    const progressContainer = document.getElementById("progress-container");
    const progressText = document.getElementById("progress-text");
    const progressBar = document.getElementById("progress-bar-fill");
    const cancelBtn = document.getElementById("cancel-btn");
    const failuresDiv = document.getElementById("failures-list");
    
    try {
        const res = await fetch("/admin/sync_status");
        if (!res.ok) throw new Error("API failed");
        
        const data = await res.json();
        
        if (data.status === "processing") {
            syncWasRunning = true; 
            btn.disabled = true;
            btn.innerText = "Sync in Progress...";
            progressContainer.style.display = "block";
            
            // 🚀 FIX: Lock down the button properties if a cancellation request is active
            if (isCancelling) {
                cancelBtn.style.display = "inline-block";
                cancelBtn.disabled = true;
                cancelBtn.innerText = "Cancelling...";
            } else {
                cancelBtn.style.display = "inline-block";
                cancelBtn.disabled = false;
                cancelBtn.innerText = "Cancel Refresh";
            }
            
            const current = data.current || 0;
            const total = data.total || 0;
            progressText.innerText = `Updating: ${current} / ${total} contests finished`;
            
            const percent = total > 0 ? (current / total) * 100 : 0;
            progressBar.style.width = `${percent}%`;
            
            if (data.failed_contests && data.failed_contests.length > 0) {
                failuresDiv.innerHTML = "<strong>Failed Contests:</strong><br>" + data.failed_contests.join("<br>");
                failuresDiv.style.display = "block";
            } else {
                failuresDiv.style.display = "none";
            }
            
            isPolling = false;
            setTimeout(checkStatus, 2000);
        } else {
            // Failsafe trigger: fires a clean reload once the worker halts execution loop
            if (syncWasRunning) {
                window.location.reload();
                return;
            }

            if (data.status === "completed" || data.status === "cancelled" || data.status === "failed") {
                progressContainer.style.display = "block";
                progressText.innerText = `Job ${data.status.toUpperCase()}! ${data.current || 0} / ${data.total || 0} successful.`;
                progressBar.style.width = data.status === "completed" ? "100%" : "0%";
                cancelBtn.style.display = "none";
                
                if (data.status === "failed" && data.error) {
                    progressText.innerText += ` Error: ${data.error}`;
                }

                if (data.failed_contests && data.failed_contests.length > 0) {
                    failuresDiv.innerHTML = "<strong>Failed Contests:</strong><br>" + data.failed_contests.join("<br>");
                    failuresDiv.style.display = "block";
                } else {
                    failuresDiv.style.display = "none";
                }
                
                btn.disabled = false;
                btn.innerText = "Refresh Results (default: all contests are refreshed)";
            } else {
                progressContainer.style.display = "none";
                btn.disabled = false;
                btn.innerText = "Refresh Results (default: all contests are refreshed)";
            }
            isPolling = false;
        }
    } catch (e) {
        console.error("Error polling sync status:", e);
        isPolling = false;
        setTimeout(checkStatus, 5000);
    }
}

async function startRefresh() {
    const btn = document.getElementById("refresh-btn");
    const limitInput = document.getElementById("refresh-limit").value;
    const progressContainer = document.getElementById("progress-container");
    const progressText = document.getElementById("progress-text");
    const progressBar = document.getElementById("progress-bar-fill");
    const failuresDiv = document.getElementById("failures-list");
    
    btn.disabled = true;
    btn.innerText = "Initiating...";
    isCancelling = false; 

    // Form data to pass the limit to the backend
    const formData = new URLSearchParams();
    if (limitInput && limitInput.trim() !== "") {
        formData.append("limit", limitInput.trim());
    }
    
    try {
        const res = await fetch("/admin/refresh_results", { 
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: formData.toString()
        });
        
        if (res.status === 409) {
            alert("A sync job is already running.");
            checkStatus();
            return;
        }
        if (!res.ok) {
            const text = await res.text();
            try {
                const err = JSON.parse(text);
                alert("Error: " + (err.message || "Failed to trigger refresh"));
            } catch(e) {
                alert("Error: Failed to trigger refresh.");
            }
            btn.disabled = false;
            btn.innerText = "Refresh Results";
            return;
        }
        
        syncWasRunning = true; 
        progressContainer.style.display = "block";
        progressText.innerText = "Synchronizing: 0 / 0 contests finished";
        progressBar.style.width = "0%";
        failuresDiv.style.display = "none";
        
        setTimeout(checkStatus, 1000);
    } catch (e) {
        alert("Network error starting sync: " + e);
        btn.disabled = false;
        btn.innerText = "Refresh Results";
    }
}

async function cancelSync() {
    const cancelBtn = document.getElementById("cancel-btn");
    
    // 🚀 Prime the state tracker immediately
    isCancelling = true; 
    cancelBtn.disabled = true;
    cancelBtn.innerText = "Cancelling...";
    
    try {
        const res = await fetch("/admin/cancel_sync", { method: "POST" });
        if (!res.ok) {
            alert("Failed to cancel sync.");
            isCancelling = false; // Reset tracker if the HTTP execution layer fails
            cancelBtn.disabled = false;
            cancelBtn.innerText = "Cancel Refresh";
            return;
        }
        checkStatus();
    } catch (e) {
        alert("Error cancelling sync: " + e);
        isCancelling = false; // Reset tracker on network crash
        cancelBtn.disabled = false;
        cancelBtn.innerText = "Cancel Refresh";
    }
}

async function checkCFAPI() {
    const el = document.getElementById("cf-status");
    try {
        el.innerText = "Checking Codeforces API...";
        el.className = "cf-status loading";

        const res = await fetch("/admin/check_cf_api", { method: "POST" });
        const text = await res.text();
        const data = JSON.parse(text);

        if (data.status === "success") {
            el.className = "cf-status success";
            el.innerText = data.message;
        } else {
            el.className = "cf-status error";
            el.innerText = data.message;
        }
    } catch (err) {
        el.className = "cf-status error";
        el.innerText = "Request failed";
    }
}
</script>
</body>
</html>
